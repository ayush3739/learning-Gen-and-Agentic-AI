    {
      "id": "1nWam8RvJ0kfr-NqLM6wv",
      "type": "text",
      "x": 1398.184344621122,
      "y": 159.9718942621609,
      "width": 215.59991455078125,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1e1e1e",
