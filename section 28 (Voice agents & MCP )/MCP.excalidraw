    {
      "id": "inWGuAfxlcS-jFzZmYTzI",
      "type": "text",
      "x": 229.4682193613517,
      "y": -154.7507576207007,
      "width": 1678.599853515625,
      "height": 210,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
